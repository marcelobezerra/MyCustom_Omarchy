TARGET_OS_NAME="Omarchy"

ESP_PATH="/boot"

KERNEL_CMDLINE[default]+="root=PARTUUID=947343fb-8546-4a35-b813-629e2a8af124 zswap.enabled=0 rootflags=subvol=@ rw rootfstype=btrfs nvidia-drm.modeset=1 nvidia_drm.fbdev=1 threadirqs"
KERNEL_CMDLINE[default]+=" quiet splash mitigations=off ipv6.disable=1 acpi_enforce_resources=lax loglevel=0 systemd.show_status=false rd.udev.log_level=0 vt.global_cursor_default=0"

ENABLE_UKI=yes
CUSTOM_UKI_NAME="omarchy"

ENABLE_LIMINE_FALLBACK=yes

# Find and add other bootloaders
FIND_BOOTLOADERS=yes

BOOT_ORDER="*, *fallback, Snapshots"

MAX_SNAPSHOT_ENTRIES=5

SNAPSHOT_FORMAT_CHOICE=5
KERNEL_CMDLINE[default]+=""
